# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# PostgreSQL (async SQLAlchemy + asyncpg)
DATABASE_URL=postgresql+asyncpg://tender:tender@postgres:5432/tender

# Redis (Celery broker / result backend)
REDIS_URL=redis://redis:6379/0

# Опционально: переопределить брокер и бэкенд Celery
# CELERY_BROKER_URL=redis://redis:6379/0
# CELERY_RESULT_BACKEND=redis://redis:6379/0

# Каталог промптов (в Docker по умолчанию /app/prompts; см. volume в docker-compose)
# PROMPTS_DIR=prompts

# Google Gemini
GEMINI_API_KEY=your_gemini_api_key
# Опционально: базовый URL REST API (прокси; без схемы/пути к модели — только хост, путь /v1beta/... добавляет адаптер)
GEMINI_BASE_URL=https://gemini-proxy.xiii-viteker.workers.dev
# Опционально: модель и таймаут HTTP (мс)
# GEMINI_MODEL=gemini-2.5-flash
# GEMINI_TIMEOUT_MS=180000
# Лимит токенов ответа (малый = обрыв длинного текста в чате и PDF)
# GEMINI_MAX_OUTPUT_TOKENS=16384
